# =============================================================================
# Ampoulex Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Flask Configuration
# -----------------------------------------------------------------------------
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
# For local development:
DATABASE_URL=postgresql://username:password@localhost:5432/ampoulex_db

# For production (e.g., Neon, Cloud SQL):
# DATABASE_URL=postgresql://user:pass@host:5432/ampoulex?sslmode=require&connect_timeout=10

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=8080
HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Session Configuration
# -----------------------------------------------------------------------------
PERMANENT_SESSION_LIFETIME_HOURS=24

# -----------------------------------------------------------------------------
# Email Configuration (Optional - for notifications)
# -----------------------------------------------------------------------------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@ampoulex.com

# -----------------------------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------------------------
UPLOAD_FOLDER=/app/uploads
MAX_UPLOAD_SIZE_MB=16

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
MIN_PASSWORD_LENGTH=8

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_SOCKETIO=True
ENABLE_EMAIL_NOTIFICATIONS=False
ENABLE_AUTO_JOURNAL_ENTRIES=True

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=/app/logs/ampoulex.log
