# .env.example

# The secret key for the Flask application, used for session management and data protection
SECRET_KEY='your_secret_key_here'

# The database URL for the application, should include username, password, host, and database name
DATABASE_URL='your_database_url_here'

# The port for the Flask application to run on
PORT=8080

# The environment for Flask, should be 'development' or 'production'
FLASK_ENV='production'

# Other optional configurations
DEBUG=False
ALLOWED_HOSTS='*'
